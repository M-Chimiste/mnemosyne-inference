#!/usr/bin/env bash
# ──────────────────────────────────────────────────────────────────
# vllm-ctl — Control tool for the containerized vLLM Manager
#
# Usage (see `vllm-ctl help` for the full list):
#   Container:  build, start, stop, restart, logs [-f], shell
#   Model:      status, load <model> [opts], unload, list, models
#   Config:     reload, storage
#   Installs:   install, install-cancel, install-retry, install-status,
#               cache-delete
#   Downloads:  download, download-status, downloads
#   Testing:    chat <prompt>
# ──────────────────────────────────────────────────────────────────

COMPOSE_DIR="${VLLM_COMPOSE_DIR:-$HOME/vllm-manager}"
# VLLM_MANAGER_URL is the legacy variable from the single-plane prototype; it
# now serves as a backward-compatible fallback for the admin URL only.
# /v1/* is steered by VLLM_INFERENCE_URL (default :8000).
ADMIN_URL="${VLLM_ADMIN_URL:-${VLLM_MANAGER_URL:-http://localhost:8001}}"
INFERENCE_URL="${VLLM_INFERENCE_URL:-http://localhost:8000}"

load_admin_password() {
  [[ -n "${ADMIN_PASSWORD:-}" ]] && return
  local env_file="${COMPOSE_DIR}/.env"
  [[ -r "$env_file" ]] || return
  ADMIN_PASSWORD="$(grep -E '^ADMIN_PASSWORD=' "$env_file" \
    | head -1 | cut -d= -f2- \
    | sed -e 's/^["'"'"']//' -e 's/["'"'"']$//')"
  export ADMIN_PASSWORD
}
load_admin_password

red()    { printf '\033[31m%s\033[0m\n' "$*"; }
green()  { printf '\033[32m%s\033[0m\n' "$*"; }
yellow() { printf '\033[33m%s\033[0m\n' "$*"; }
bold()   { printf '\033[1m%s\033[0m\n' "$*"; }

compose() { docker compose -f "${COMPOSE_DIR}/docker-compose.yml" "$@"; }

api() {
  local method="$1"; shift
  local path="$1";   shift
  local auth_args=()
  [[ -n "${ADMIN_PASSWORD:-}" ]] && auth_args=(-u "admin:${ADMIN_PASSWORD}")
  curl -sf -X "$method" "${ADMIN_URL}${path}" \
    -H "Content-Type: application/json" \
    "${auth_args[@]}" "$@"
}

# ── commands ───────────────────────────────────────────────────────

cmd_build() {
  green "Building vLLM Manager image (this takes a few minutes first time) ..."
  compose build
  green "✓ Image built."
}

cmd_start() {
  green "Starting vLLM Manager container ..."
  compose up -d
  echo ""
  # Wait briefly for the manager to come up
  for i in {1..15}; do
    sleep 1
    if curl -sf "${INFERENCE_URL}/health" &>/dev/null; then
      green "✓ Inference is up at ${INFERENCE_URL}"
      echo ""
      if [[ -n "${ADMIN_PASSWORD:-}" ]]; then
        cmd_status
      else
        yellow "Admin port is loopback-only (ADMIN_PASSWORD unset)."
        yellow "Use: docker exec vllm-manager curl http://127.0.0.1:8001/manager/status"
        yellow "Or set ADMIN_PASSWORD in ${COMPOSE_DIR}/.env for host-side admin commands."
      fi
      return
    fi
  done
  yellow "Manager started but not responding yet — check: vllm-ctl logs"
}

cmd_stop() {
  yellow "Stopping vLLM Manager (unloads model and frees VRAM) ..."
  compose down
  green "✓ Stopped."
}

cmd_restart() {
  compose restart vllm-manager
  green "✓ Restarted."
}

cmd_status() {
  echo ""
  bold "── Container Status ──────────────────────────────────────"
  local state
  state=$(docker inspect --format='{{.State.Status}}' vllm-manager 2>/dev/null || echo "not found")
  case "$state" in
    running) green  "  Container: running" ;;
    exited)  yellow "  Container: stopped (exited)" ;;
    *)       red    "  Container: ${state}" ;;
  esac

  echo ""
  bold "── Manager Status ────────────────────────────────────────"
  local result
  result=$(api GET /manager/status 2>/dev/null) || {
    yellow "  Admin not reachable at ${ADMIN_URL}"
    yellow "  Start with: vllm-ctl start"
    return
  }

  echo "$result" | python3 -c "
import sys, json
d = json.load(sys.stdin)
GREEN, YELLOW, RESET = '\033[32m', '\033[33m', '\033[0m'

model     = d.get('loaded_model') or 'none'
loading   = d.get('loading', False)
swap_to   = d.get('swap_target')
alias     = d.get('alias')
gpus      = d.get('gpus')
quant     = d.get('quantization') or '-'
mml       = d.get('max_model_len')
storage   = d.get('storage_location') or '-'
tp        = d.get('tp_size')
gpu_mem   = d.get('gpu_mem_util')
loaded_at = d.get('loaded_at_human') or '-'
idle      = d.get('idle_seconds')
evict_in  = d.get('seconds_until_eviction')
inflight  = d.get('inflight_requests', 0)

if loading:
    target = swap_to or '?'
    print(f'{YELLOW}  Status:  Loading {target} ...{RESET}')
elif model == 'none':
    print(f'{YELLOW}  Status:  No model loaded{RESET}')
else:
    gpus_str = '[' + ','.join(str(x) for x in gpus) + ']' if isinstance(gpus, list) else str(gpus or '?')
    print(f'{GREEN}  Status:  Ready{RESET}')
    if alias:
        print(f'  Alias:   {alias}')
    print(f'  Model:   {model}')
    print(f'  GPUs:    {gpus_str}   tp={tp}   gpu_mem={gpu_mem}')
    if quant != '-' or mml is not None:
        mml_s = str(mml) if mml is not None else '-'
        print(f'  Quant:   {quant}   max_model_len={mml_s}')
    print(f'  Storage: {storage}')
    print(f'  Loaded:  {loaded_at}')
    if idle is not None:
        if evict_in is not None:
            print(f'  Idle:    {idle:.0f}s   evict in {evict_in:.0f}s   inflight={inflight}')
        else:
            print(f'  Idle:    {idle:.0f}s   evict disabled   inflight={inflight}')
"
  echo ""
}

cmd_load() {
  local model="$1"; shift

  if [[ -z "$model" ]]; then
    red "Usage: vllm-ctl load <model-id> [--tp N] [--gpu-mem 0.90] [-- <extra vllm args...>]"
    exit 1
  fi

  local tp=2
  local gpu_mem=0.90
  local extra_args=()
  local pass_through=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --tp)      tp="$2";      shift 2 ;;
      --gpu-mem) gpu_mem="$2"; shift 2 ;;
      --)        pass_through=true; shift ;;
      *)
        if $pass_through; then extra_args+=("$1"); fi
        shift ;;
    esac
  done

  local extra_json
  extra_json=$(printf '%s\n' "${extra_args[@]}" | python3 -c "
import sys, json
lines = [l.strip() for l in sys.stdin if l.strip()]
print(json.dumps(lines))
")

  local payload
  payload=$(python3 -c "
import json
print(json.dumps({
  'model':     '${model}',
  'tp':        ${tp},
  'gpu_mem':   ${gpu_mem},
  'extra_args': ${extra_json},
}))
")

  echo ""
  green "Loading: ${model}"
  echo  "  tp=${tp}  gpu_mem=${gpu_mem}"
  [[ ${#extra_args[@]} -gt 0 ]] && echo "  extra: ${extra_args[*]}"
  yellow "  Large models can take several minutes to load ..."
  echo ""

  local result
  result=$(api POST /manager/load -d "$payload") || {
    red "Failed to reach admin at ${ADMIN_URL}"
    red "Is it running? Try: vllm-ctl start"
    exit 1
  }

  echo "$result" | python3 -c "
import sys, json
d = json.load(sys.stdin)
if d.get('status') == 'loaded':
    print(f\"  ✓ {d['model']} loaded (tp={d.get('tp','?')})\")
else:
    print(json.dumps(d, indent=2))
"
  echo ""
}

cmd_unload() {
  echo ""
  yellow "Unloading model and freeing VRAM ..."
  local result
  result=$(api POST /manager/unload) || { red "Manager not reachable"; exit 1; }
  echo "$result" | python3 -c "
import sys, json
d = json.load(sys.stdin)
was = d.get('was', '')
if was:
    print(f'  ✓ Unloaded: {was}')
else:
    print(f'  {d.get(\"status\",\"done\")}')
"
  echo ""
}

cmd_reload() {
  echo ""
  green "Reloading config ..."
  local result
  result=$(api POST /manager/reload) || { red "  ✗ Reload failed or admin not reachable"; exit 1; }
  echo "$result" | python3 -c "
import sys, json
d = json.load(sys.stdin)
s = d['sync']; r = d['reconcile']
print(f\"  ✓ Sync:        +{s['added']}  ~{s['updated']}  -{s['removed_config_orphans']}  (ui_preserved={s['ui_preserved']}  ui_overwritten={s['ui_overwritten']})\")
print(f\"  ✓ Reconcile:   installed={r['installed']}  partial={r['partial']}  location_missing={r['location_missing']}\")
"
  echo ""
}

cmd_list() {
  echo ""
  bold "── Configured Profiles ───────────────────────────────────"
  local result
  result=$(api GET /manager/profiles) || { red "Manager not reachable"; exit 1; }
  echo "$result" | python3 -c "
import sys, json
d = json.load(sys.stdin)
profiles = d.get('profiles', [])
if not profiles:
    print('  (no profiles configured — edit \$VLLM_COMPOSE_DIR/config.yaml)')
else:
    for p in profiles:
        gpus = p['gpus']
        gpus_str = '[' + ','.join(str(x) for x in gpus) + ']' if isinstance(gpus, list) else gpus
        q = p.get('quantization') or '-'
        print(f\"  • {p['alias']:24}  {p['model']:50}  gpus={gpus_str:8}  quant={q:6}  storage={p['storage']}\")
"
  echo ""
}

cmd_storage() {
  echo ""
  bold "── Storage Locations ─────────────────────────────────────"
  local result
  result=$(api GET /manager/storage) || { red "Manager not reachable"; exit 1; }
  echo "$result" | python3 -c "
import sys, json
d = json.load(sys.stdin)
locs = d.get('locations', [])
if not locs:
    print('  (no storage locations configured)')
else:
    for l in locs:
        free = f\"{l['free_bytes']/1e9:.1f} GB\" if l.get('free_bytes') else '?'
        total = f\"{l['total_bytes']/1e9:.1f} GB\" if l.get('total_bytes') else '?'
        flags = []
        if l['is_default']: flags.append('default')
        if not l['writable']: flags.append('READONLY')
        flag_str = ('  [' + ', '.join(flags) + ']') if flags else ''
        print(f\"  • {l['name']:16}  {l['path']:40}  free={free}/{total}{flag_str}\")
"
  echo ""
}

cmd_models() {
  echo ""
  bold "── Cached Models (HF volume) ─────────────────────────────"
  local result
  result=$(api GET /manager/models) || { red "Manager not reachable"; exit 1; }
  echo "$result" | python3 -c "
import sys, json
d = json.load(sys.stdin)
models = d.get('cached_models', [])
if not models:
    print('  (no models cached yet)')
else:
    for m in models:
        size = f\"{m['size_gb']} GB\" if m.get('size_gb') else '?'
        print(f\"  • {m['model']}  [{size}]\")
print(f\"\nCache: {d.get('hf_cache')}\")
"
  echo ""
}

cmd_logs() {
  if [[ "$1" == "-f" ]]; then
    compose logs -f vllm-manager
  else
    compose logs --tail=100 vllm-manager
  fi
}

cmd_chat() {
  local prompt="$*"
  [[ -z "$prompt" ]] && { red "Usage: vllm-ctl chat <prompt>"; exit 1; }

  local model
  model=$(api GET /manager/status | python3 -c "
import sys,json; d=json.load(sys.stdin)
m=d.get('loaded_model')
print(m if m else '')
") || { red "Manager not reachable"; exit 1; }

  [[ -z "$model" ]] && { red "No model loaded. Use: vllm-ctl load <model>"; exit 1; }

  local payload
  payload=$(python3 -c "
import json
print(json.dumps({
  'model': '${model}',
  'messages': [{'role': 'user', 'content': '''${prompt}'''}],
  'stream': False
}))
")

  echo ""
  bold "Model:  ${model}"
  bold "Prompt: ${prompt}"
  echo "──────────────────────────────────────────────────────────"
  local auth_args=()
  [[ -n "${INFERENCE_API_KEY:-}" ]] && auth_args=(-H "Authorization: Bearer ${INFERENCE_API_KEY}")
  curl -sf -X POST "${INFERENCE_URL}/v1/chat/completions" \
    -H "Content-Type: application/json" \
    "${auth_args[@]}" \
    -d "$payload" \
    | python3 -c "
import sys,json
d=json.load(sys.stdin)
print(d['choices'][0]['message']['content'])
"
  echo ""
}

cmd_shell() {
  docker exec -it vllm-manager /bin/bash
}

cmd_download() {
  local model="$1"; shift

  if [[ -z "$model" ]]; then
    red "Usage: vllm-ctl download <model-id> [--revision main] [--token hf_...]"
    exit 1
  fi

  local revision="main"
  local hf_token=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --revision) revision="$2"; shift 2 ;;
      --token)    hf_token="$2"; shift 2 ;;
      *) shift ;;
    esac
  done

  local payload
  payload=$(python3 -c "
import json
d = {
  'model': '${model}',
  'revision': '${revision}',
  'ignore_patterns': ['*.pt', '*.bin', '*.msgpack', 'flax_model*', 'tf_model*', 'rust_model*'],
}
if '${hf_token}':
    d['hf_token'] = '${hf_token}'
print(json.dumps(d))
")

  echo ""
  green "Queuing download: ${model}"
  local result
  result=$(api POST /manager/download -d "$payload") || { red "Admin not reachable"; exit 1; }

  local poll_path status
  poll_path=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin).get('poll',''))")
  status=$(echo "$result"    | python3 -c "import sys,json; print(json.load(sys.stdin).get('status',''))")

  if [[ "$status" == "already_downloading" ]]; then
    yellow "  Already downloading — polling for progress ..."
  else
    green  "  Download started in background."
  fi

  echo   "  Poll: vllm-ctl download-status ${model}"
  echo ""

  # Optionally follow progress
  read -rp "  Follow progress? [Y/n] " follow
  if [[ "${follow,,}" != "n" ]]; then
    cmd_download_follow "$model"
  fi
}

cmd_download_status() {
  local model="$1"
  [[ -z "$model" ]] && { red "Usage: vllm-ctl download-status <model-id>"; exit 1; }

  local encoded
  encoded=$(python3 -c "import urllib.parse; print(urllib.parse.quote('${model}', safe=''))")

  local result
  result=$(api GET "/manager/download/${encoded}") || { red "Manager not reachable or no record for '${model}'"; exit 1; }

  echo "$result" | python3 -c "
import sys, json, time
d = json.load(sys.stdin)
status = d.get('status','?')
colors = {'complete': '\033[32m', 'error': '\033[31m', 'downloading': '\033[33m', 'queued': '\033[33m'}
reset = '\033[0m'
color = colors.get(status, '')
print(f\"  Model:   {d.get('model')}\")
print(f\"  Status:  {color}{status}{reset}\")
if d.get('elapsed_seconds'):
    elapsed = d['elapsed_seconds']
    print(f\"  Elapsed: {int(elapsed//60)}m {int(elapsed%60)}s\")
if d.get('path'):
    print(f\"  Path:    {d['path']}\")
if d.get('error'):
    print(f\"  Error:   {d['error']}\")
"
}

cmd_download_follow() {
  local model="${1:-}"
  if [[ -z "$model" ]]; then
    # Show all active downloads
    api GET /manager/downloads | python3 -c "
import sys, json
d = json.load(sys.stdin)
active = [x for x in d['downloads'] if x['status'] in ('queued','downloading')]
if not active:
    print('  No active downloads.')
else:
    for m in active:
        print(f\"  {m['model']}: {m['status']}\")
"
    return
  fi

  echo ""
  yellow "  Following download: ${model} (Ctrl+C to stop following, download continues)"
  echo ""
  local encoded
  encoded=$(python3 -c "import urllib.parse; print(urllib.parse.quote('${model}', safe=''))")

  while true; do
    local result
    result=$(api GET "/manager/download/${encoded}" 2>/dev/null) || break
    local status
    status=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin).get('status','?'))")
    local elapsed
    elapsed=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); e=d.get('elapsed_seconds',0); print(f'{int(e//60)}m{int(e%60)}s')")

    printf "\r  [%s]  status=%-12s  elapsed=%s  " "$(date +%H:%M:%S)" "$status" "$elapsed"

    if [[ "$status" == "complete" ]]; then
      echo ""
      green "  ✓ Download complete."
      break
    elif [[ "$status" == "error" ]]; then
      echo ""
      red "  ✗ Download failed:"
      echo "$result" | python3 -c "import sys,json; print('   ', json.load(sys.stdin).get('error','unknown error'))"
      break
    fi
    sleep 5
  done
  echo ""
}

cmd_downloads() {
  echo ""
  bold "── All Downloads ─────────────────────────────────────────"
  api GET /manager/downloads | python3 -c "
import sys, json
d = json.load(sys.stdin)
items = d.get('downloads', [])
if not items:
    print('  (no download records)')
else:
    for m in items:
        status = m.get('status','?')
        colors = {'complete': '\033[32m', 'error': '\033[31m', 'downloading': '\033[33m', 'queued': '\033[33m'}
        c, r = colors.get(status,''), '\033[0m'
        elapsed = ''
        if m.get('elapsed_seconds'):
            e = m['elapsed_seconds']
            elapsed = f\" ({int(e//60)}m{int(e%60)}s)\"
        print(f\"  {c}{status:12}{r}  {m['model']}{elapsed}\")
"
  echo ""
}

cmd_install() {
  local alias="$1"; shift
  local model="$1"; shift

  if [[ -z "$alias" || -z "$model" ]]; then
    red "Usage: vllm-ctl install <alias> <model> [--revision REF] [--quant X] \\"
    red "         [--gpus all|0,1] [--max-len N] [--storage NAME] [--size-gb F] \\"
    red "         [-- vllm extra args...]"
    exit 1
  fi

  local revision="main"
  local quant=""
  local gpus="all"
  local max_len=""
  local storage=""
  local size_gb=""
  local extra_args=()
  local pass_through=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --revision) revision="$2"; shift 2 ;;
      --quant)    quant="$2";    shift 2 ;;
      --gpus)     gpus="$2";     shift 2 ;;
      --max-len)  max_len="$2";  shift 2 ;;
      --storage)  storage="$2";  shift 2 ;;
      --size-gb)  size_gb="$2";  shift 2 ;;
      --)         pass_through=true; shift ;;
      *)
        if $pass_through; then extra_args+=("$1"); fi
        shift ;;
    esac
  done

  local extra_json
  extra_json=$(printf '%s\n' "${extra_args[@]}" | python3 -c "
import sys, json
lines = [l.strip() for l in sys.stdin if l.strip()]
print(json.dumps(lines))
")

  local payload
  payload=$(python3 -c "
import json
gpus_raw = '${gpus}'
if gpus_raw == 'all':
    gpus = 'all'
else:
    gpus = [int(x) for x in gpus_raw.split(',') if x.strip()]
d = {
  'alias':    '${alias}',
  'model':    '${model}',
  'revision': '${revision}',
  'gpus':     gpus,
  'extra_args': ${extra_json},
}
if '${quant}':   d['quantization']      = '${quant}'
if '${max_len}': d['max_model_len']     = int('${max_len}')
if '${storage}': d['storage']           = '${storage}'
if '${size_gb}': d['size_estimate_gb']  = float('${size_gb}')
print(json.dumps(d))
")

  echo ""
  green "Queuing install: ${alias} ← ${model}"
  echo  "  revision=${revision}  gpus=${gpus}"
  [[ -n "$quant" ]]   && echo "  quantization=${quant}"
  [[ -n "$max_len" ]] && echo "  max_model_len=${max_len}"
  [[ -n "$storage" ]] && echo "  storage=${storage}"
  [[ -n "$size_gb" ]] && echo "  size_estimate_gb=${size_gb}"
  echo ""

  local result
  result=$(api POST /manager/install -d "$payload") || {
    red "  ✗ Install request failed (admin not reachable or 4xx)."
    exit 1
  }
  echo "$result" | python3 -c "
import sys, json
d = json.load(sys.stdin)
print(f\"  Status: {d.get('status','?')}\")
print(f\"  Poll:   vllm-ctl install-status {d.get('alias','?')}\")
"
  echo ""
}

cmd_install_cancel() {
  local alias="$1"
  [[ -z "$alias" ]] && { red "Usage: vllm-ctl install-cancel <alias>"; exit 1; }
  api POST "/manager/install/${alias}/cancel" | python3 -c "
import sys, json
d = json.load(sys.stdin)
print(f\"  Status: {d.get('status','?')} ({d.get('alias','')})\")
"
}

cmd_install_retry() {
  local alias="$1"; shift
  [[ -z "$alias" ]] && { red "Usage: vllm-ctl install-retry <alias> [--force]"; exit 1; }
  local force=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force) force="?force=true"; shift ;;
      *) shift ;;
    esac
  done
  api POST "/manager/install/${alias}/retry${force}" | python3 -c "
import sys, json
d = json.load(sys.stdin)
print(f\"  Status: {d.get('status','?')} ({d.get('alias','')})\")
"
}

cmd_install_status() {
  local alias="$1"
  if [[ -z "$alias" ]]; then
    api GET /manager/catalog | python3 -c "
import sys, json
d = json.load(sys.stdin)
rows = d.get('models', [])
if not rows:
    print('  (catalog empty)')
else:
    for r in rows:
        print(f\"  {r['alias']:24}  {r['hf_model_id']:50}  status={r['status']}  revision={r.get('revision','main')}\")
"
    return
  fi
  api GET "/manager/install/${alias}" | python3 -c "
import sys, json
d = json.load(sys.stdin)
status = d.get('status','?')
print(f\"  Alias:   {d.get('alias')}\")
print(f\"  Model:   {d.get('hf_model_id')}\")
print(f\"  Status:  {status}\")
print(f\"  Revision:    {d.get('revision','main')}\")
print(f\"  Storage:     {d.get('storage_location')}\")
print(f\"  Cache path:  {d.get('cache_path') or '-'}\")
dl = d.get('download') or {}
if dl:
    bd = dl.get('bytes_downloaded') or 0
    tb = dl.get('total_bytes') or 0
    pct = (bd / tb * 100) if tb else None
    print(f\"  Download:    {dl.get('status','?')}  {bd}/{tb or '?'} bytes\" + (f' ({pct:.1f}%)' if pct is not None else ''))
    if dl.get('error'):
        print(f\"  Error:       {dl['error']}\")
    if 'elapsed_seconds' in dl:
        print(f\"  Elapsed:     {dl['elapsed_seconds']:.1f}s\")
"
}

cmd_cache_delete() {
  local alias=""
  local remove_row=false
  local model_id=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --alias) alias="$2"; shift 2 ;;
      --remove-row) remove_row=true; shift ;;
      *) model_id="$1"; shift ;;
    esac
  done
  if [[ -n "$alias" ]]; then
    if $remove_row; then
      api DELETE "/manager/install/${alias}"
    else
      api DELETE "/manager/install/${alias}/cache"
    fi
    echo ""
    return
  fi
  if [[ -z "$model_id" ]]; then
    red "Usage: vllm-ctl cache-delete <model-id>"
    red "       vllm-ctl cache-delete --alias <alias> [--remove-row]"
    exit 1
  fi
  local encoded
  encoded=$(python3 -c "import urllib.parse; print(urllib.parse.quote('${model_id}', safe=''))")
  api DELETE "/manager/cache/${encoded}"
  echo ""
}

cmd_help() {
  cat <<EOF

$(bold "vllm-ctl") — Containerized vLLM Manager
Compose dir: ${COMPOSE_DIR}
Admin URL: ${ADMIN_URL}
Inference URL: ${INFERENCE_URL}

$(bold "Container:")
  build                   Build the Docker image
  start                   Start container (docker compose up -d)
  stop                    Stop container + unload model
  restart                 Restart container
  logs [-f]               Show container logs (-f to follow)
  shell                   Open bash shell inside container

$(bold "Model control:")
  status                  Show container + loaded model info
  load <model> [opts]     Load a model (swaps out any current model)
    --tp N                  Tensor parallel size (default: 2)
    --gpu-mem 0.90          GPU memory fraction
    -- <vllm args>          Extra args passed to vllm server
  unload                  Unload current model, free all VRAM
  list                    List configured profiles (config.yaml aliases)
  models                  List models in local HF cache volume

$(bold "Config:")
  reload                  Reread config.yaml without restarting the container
  storage                 List storage locations with free space

$(bold "Installs (Phase 4):")
  install <alias> <model> [opts]  Install a model under a stable alias
    --revision <ref>              Branch/tag/commit SHA (default: main)
    --quant <q>                   Quantization (awq, fp8, ...)
    --gpus all|0,1                GPU plan (default: all)
    --max-len N                   Override max_model_len
    --storage <name>              Storage location name (default: storage.default)
    --size-gb F                   Size estimate (drives free-space pre-check)
    -- <vllm extra args>          Extra args appended verbatim
  install-cancel <alias>          SIGTERM the worker (resumable)
  install-retry <alias> [--force] Re-spawn the worker; --force wipes cache
  install-status [alias]          Show one row or list all
  cache-delete <model-id>         Legacy by-HF-id cache delete
  cache-delete --alias <alias> [--remove-row]
                                  Cache-only or full removal of an aliased install

$(bold "Downloads (legacy v0 shim — preserved):")
  download <model> [opts]     Download a model from HuggingFace Hub
    --revision <ref>            Branch/tag/commit (default: main)
    --token hf_...              HF token for this request (overrides env)
  download-status <model>     Check status of a specific download
  downloads                   List all download records

$(bold "Testing:")
  chat <prompt>           Quick one-shot chat with loaded model

$(bold "Examples:")
  vllm-ctl build
  vllm-ctl start
  vllm-ctl load Qwen/Qwen2.5-72B-Instruct-AWQ
  vllm-ctl load Qwen/Qwen3-8B --tp 1
  vllm-ctl load Qwen/Qwen2.5-72B-Instruct-AWQ -- --max-model-len 32768
  vllm-ctl chat "What is your context length?"
  vllm-ctl unload
  vllm-ctl stop

$(bold "Environment:")
  VLLM_ADMIN_URL       Override admin URL (default: http://localhost:8001)
  VLLM_INFERENCE_URL   Override inference URL (default: http://localhost:8000)
  VLLM_MANAGER_URL     Legacy admin URL fallback when VLLM_ADMIN_URL is unset
  VLLM_COMPOSE_DIR     Path to docker-compose.yml dir (default: ~/vllm-manager)
  ADMIN_PASSWORD       Admin Basic password; auto-loaded from ${COMPOSE_DIR}/.env
  INFERENCE_API_KEY    Optional bearer token for /v1/* chat requests

$(bold "HF token (for gated models):")
  Add HUGGING_FACE_HUB_TOKEN=hf_... to ${COMPOSE_DIR}/.env, then
  vllm-ctl restart (env is read once at process start; no live reload).

EOF
}

# ── dispatch ───────────────────────────────────────────────────────
case "${1:-help}" in
  build)   cmd_build ;;
  start)   cmd_start ;;
  stop)    cmd_stop ;;
  restart) cmd_restart ;;
  status)  cmd_status ;;
  load)    shift; cmd_load "$@" ;;
  unload)  cmd_unload ;;
  reload)  cmd_reload ;;
  list)    cmd_list ;;
  storage) cmd_storage ;;
  models)  cmd_models ;;
  download) shift; cmd_download "$@" ;;
  download-status) shift; cmd_download_status "$@" ;;
  downloads) cmd_downloads ;;
  install)         shift; cmd_install "$@" ;;
  install-cancel)  shift; cmd_install_cancel "$@" ;;
  install-retry)   shift; cmd_install_retry "$@" ;;
  install-status)  shift; cmd_install_status "$@" ;;
  cache-delete)    shift; cmd_cache_delete "$@" ;;
  logs)    shift; cmd_logs "$@" ;;
  chat)    shift; cmd_chat "$@" ;;
  shell)   cmd_shell ;;
  help|--help|-h) cmd_help ;;
  *) red "Unknown command: $1"; cmd_help; exit 1 ;;
esac
