# Mnemosyne Inference — example configuration.
#
# Mount this file into the container at /config/config.yaml. The host path
# is conventionally ~/vllm-manager/config.yaml; the same directory holds .env
# (see .env.example). Secrets do NOT live in this file.
#
# Edit + `vllm-ctl reload` (or SIGHUP / POST /manager/reload) re-reads the
# file without restarting the container.

server:
  inference_port: 8000              # LAN-facing OpenAI-compatible API
  admin_port: 8001                  # /ui + /manager/* — see PRD §5.10
  inference_bind: 0.0.0.0
  admin_bind: 0.0.0.0
  idle_unload_seconds: 900          # 15 min default; null disables idle eviction
  startup_timeout_seconds: 600
  swap_queue_timeout_seconds: 300   # how long /v1 waits during a model swap before 504

storage:
  default: nvme-fast
  locations:
    - name: nvme-fast
      path: /storage/nvme/hf-cache  # bind-mount the host drive here in compose
    - name: archive
      path: /storage/raid/hf-cache

defaults:
  gpu_memory_utilization: 0.90
  trust_remote_code: true
  max_model_len: null               # null → vLLM derives from model config

models:
  # Tensor-parallel across both GPUs.
  - alias: qwen-72b-awq
    model: Qwen/Qwen2.5-72B-Instruct-AWQ
    quantization: awq
    gpus: all                       # or [0] or [1] or [0,1]
    max_model_len: 32768
    storage: nvme-fast

  # Single GPU — pin to GPU 0.
  - alias: qwen-coder-7b
    model: Qwen/Qwen2.5-Coder-7B-Instruct
    gpus: [0]

  # Multimodal on GPU 1 with a vLLM flag passed through verbatim.
  - alias: llama-vision
    model: meta-llama/Llama-3.2-11B-Vision-Instruct
    gpus: [1]
    storage: archive
    extra_args:
      - --limit-mm-per-prompt
      - image=4
