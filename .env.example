# Mnemosyne Inference — runtime secrets.
#
# Mount this at /config/.env (host path conventionally ~/vllm-manager/.env).
# Read once at process startup; changes require a container restart.
# .env itself is gitignored — only this example file is checked in.

# HTTP Basic password for the admin plane (UI + /manager/*).
# If unset, the admin port refuses to bind to anything other than 127.0.0.1
# and logs a warning. Set this before exposing :8001 to the LAN.
ADMIN_PASSWORD=

# Optional. Required only for gated HuggingFace repos (e.g. Llama models).
# Read by the install subprocess; never surfaced through the UI.
HUGGING_FACE_HUB_TOKEN=

# Optional. If set, /v1/* requires `Authorization: Bearer <key>`.
# If unset, the inference port is open on the LAN (single-user assumption).
INFERENCE_API_KEY=

# Optional. Postgres DSN for the central token-usage ledger. Only used when
# config.yaml has `token_sidecar.enabled: true`. Held in .env (not config.yaml)
# because it embeds a password.
TOKEN_SIDECAR_POSTGRES_DSN=
